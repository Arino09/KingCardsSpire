    speakerName: "\u5EFA\u7B51\u5E08"
    bodyText: "\u201C\u6240\u4EE5\uFF0C\u6216\u8BB8\u6211\u4EEC\u5F88\u5FEB\u5C31\u4E0D\u5F97\u4E0D\u820D\u5F03\u6700\u5916\u9762\u7684\u90A3\u4E00\u5708\u3002\u201D\r\n\u201C\u4E5F\u5C31\u662F\u2026\u2026\u7B2C\u4E94\u5927\u9646\u3002\u201D"
    isChoice: 0
    nextId: 
