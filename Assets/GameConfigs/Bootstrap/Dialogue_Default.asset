  - id: npc_4_2_4
    timingKind: 4
    backgroundId: NPC4/6
    characterId: 
    speakerName: 
    bodyText: "\u4F60\u5F20\u4E86\u5F20\u5634\uFF0C\u60F3\u8BF4\u4E9B\u4EC0\u4E48\uFF0C\u5374\u53D1\u73B0\u81EA\u5DF1\u4E00\u53E5\u8BDD\u4E5F\u53D1\u4E0D\u51FA\u6765\u3002\r\n\u90A3\u540D\u533B\u751F\u4FEF\u4E0B\u8EAB\uFF0C\u5C06\u4E24\u4E2A\u793C\u76D2\u8F7B\u8F7B\u653E\u5728\u4F60\u9762\u524D\uFF0C\u53C8\u4ECE\u53E3\u888B\u91CC\u62FF\u51FA\u4E00\u7247\u836F\uFF0C\u653E\u8FDB\u4E86\u5176\u4E2D\u4E00\u4E2A\u76D2\u5B50\u91CC\u3002\r\n\u7D27\u63A5\u7740\uFF0C\u4ED6\u53CC\u624B\u98DE\u5FEB\u52A8\u4F5C\u8D77\u6765\u3002\r\n\u4E24\u4E2A\u76D2\u5B50\u5728\u4ED6\u624B\u4E2D\u4E0D\u65AD\u4EA4\u6362\u4F4D\u7F6E\uFF0C\u5FEB\u5F97\u51E0\u4E4E\u770B\u4E0D\u6E05\u3002"
