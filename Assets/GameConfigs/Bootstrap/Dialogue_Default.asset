    speakerName: 
    bodyText: "\u5F69\u706F\u5F00\u59CB\u65CB\u8F6C\uFF0C\u8857\u9053\u5F00\u59CB\u626D\u66F2\uFF0C\u4F60\u7684\u610F\u8BC6\u4E5F\u4E00\u70B9\u70B9\u6C89\u4E86\u4E0B\u53BB\u3002\r\n\u7B49\u4F60\u518D\u6B21\u6E05\u9192\u8FC7\u6765\u65F6\uFF0C\u81EA\u5DF1\u5DF2\u7ECF\u7AD9\u5728\u4E86\u623F\u95E8\u5916\u3002"
