    timingKind: 4
    backgroundId: NPC11/3
    characterId: NPC/1_1
    speakerName: "\u56DA\u5F92"
    bodyText: "\u201C\u5B69\u5B50\uFF0C\u4ECA\u5929\u6211\u544A\u8BC9\u4F60\u8FD9\u4E9B\uFF0C\u5C31\u50CF\u5F53\u5E74\u90A3\u4F4D\u524D\u8F88\u544A\u8BC9\u6211\u4E00\u6837\u3002\u4F60\u4E0B\u6B21\u518D\u6765\u65F6\uFF0C\u53EF\u80FD\u5C31\u89C1\u4E0D\u5230\u6211\u4E86\u3002\u5C3D\u7BA1\u5854\u91CC\u7684\u90A3\u4E9B\u5BB6\u4F19\u770B\u4E0D\u8D77\u6211\u4EEC\uFF0C\u4F46\u4ED6\u4EEC\u4E5F\u5FC5\u987B\u9075\u5B88\u5854\u7684\u7ADE\u9009\u89C4\u5219\u3002\u5728\u4F60\u5931\u8D25\u4E4B\u524D\uFF0C\u4ED6\u4EEC\u4E0D\u6562\u4F24\u5BB3\u4F60\u3002\u201D\r\n\u201C\u52A1\u5FC5\u8981\u575A\u6301\u4E0B\u53BB\u3002\u6211\u4EEC\u5E0C\u7FBD\u4EBA\uFF0C\u6C38\u8FDC\u4E0D\u4F1A\u653E\u5F03\uFF01\u201D"
