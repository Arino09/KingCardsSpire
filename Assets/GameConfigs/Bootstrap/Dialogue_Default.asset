    speakerName: 
    bodyText: "\u548C\u5468\u56F4\u90A3\u4E9B\u6A21\u7CCA\u4E0D\u6E05\u7684\u4EBA\u4E0D\u540C\uFF0C\u4ED6\u7684\u8138\u5374\u662F\u6E05\u6670\u7684\u3002\r\n\u90A3\u662F\u4E00\u5F20\u5F88\u5E74\u8F7B\u7684\u8138\uFF0C\u753B\u7740\u5938\u5F20\u7684\u6CB9\u5F69\uFF0C\u9F3B\u5C16\u9876\u7740\u4E00\u4E2A\u7EA2\u8272\u5706\u7403\uFF0C\u5634\u89D2\u59CB\u7EC8\u626C\u7740\u7528\u529B\u8FC7\u5934\u7684\u7B11\u3002\r\n\u4F60\u7A7F\u8FC7\u4EBA\u7FA4\uFF0C\u8D70\u5230\u4E86\u4ED6\u7684\u9762\u524D\u3002\r\r"
