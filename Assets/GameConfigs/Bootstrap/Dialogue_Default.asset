    speakerName: 
    bodyText: "\u4E0D\u77E5\u4E3A\u4F55\uFF0C\u4F60\u603B\u89C9\u5F97\u90A3\u7B11\u5BB9\u6709\u4E9B\u5947\u602A\u3002\r\n\u53EA\u89C1\u4ED6\u4ECE\u6000\u91CC\u62FF\u51FA\u4E24\u4E2A\u793C\u76D2\uFF0C\u8F7B\u8F7B\u653E\u5230\u684C\u4E0A\uFF0C\u53C8\u53D6\u51FA\u4E00\u4E2A\u82F9\u679C\uFF0C\u5F53\u7740\u4F60\u7684\u9762\u5C06\u82F9\u679C\u653E\u8FDB\u4E86\u5176\u4E2D\u4E00\u4E2A\u76D2\u5B50\u91CC\u3002\r\n\u968F\u540E\uFF0C\u4ED6\u53CC\u624B\u98DE\u5FEB\u52A8\u4F5C\u8D77\u6765\uFF0C\u4E24\u4E2A\u76D2\u5B50\u5728\u4ED6\u624B\u4E2D\u4E0D\u65AD\u4EA4\u6362\u4F4D\u7F6E\uFF0C\u5FEB\u5F97\u8BA9\u4EBA\u51E0\u4E4E\u770B\u4E0D\u6E05\u3002\r\r\r"
