    speakerName: "\u5EFA\u7B51\u5E08"
    bodyText: "\u201C\u539F\u672C\uFF0C\u8FD9\u4E2A\u4E16\u754C\u53EA\u6709\u4E00\u6574\u5757\u5927\u9646\u3002\u201D\r\n\u201C\u4F46\u7EDF\u6CBB\u8005\u547D\u4EE4\u6211\u5C06\u5B83\u62C6\u5206\u5F00\u6765\uFF0C\u5206\u6210\u5982\u4ECA\u8FD9\u4E00\u5708\u53C8\u4E00\u5708\u7684\u7ED3\u6784\u3002\u53EA\u6709\u8FD9\u6837\uFF0C\u4ED6\u624D\u80FD\u66F4\u597D\u5730\u5B8C\u6210\u81EA\u5DF1\u7684\u7EDF\u6CBB\u3002\u201D\r\n\u201C\u81F3\u4E8E\u5854\u7A76\u7ADF\u662F\u5982\u4F55\u76D1\u7BA1\u8FD9\u4E9B\u5927\u9646\u7684\uFF0C\u90A3\u5E76\u4E0D\u5728\u6211\u7684\u804C\u8D23\u4E4B\u5185\u3002\u201D"
    isChoice: 0
    nextId: npc_12_2_7
    choices: []
  - id: npc_12_2_7
    timingKind: 4
    backgroundId: NPC12/4
    characterId: NPC/1_2
    speakerName: "\u5EFA\u7B51\u5E08"
    bodyText: "\u201C\u6211\u53EA\u8D1F\u8D23\u5EFA\u9020\u3002\u66F4\u91CD\u8981\u7684\u662F\uFF0C\u6211\u4EAB\u53D7\u521B\u9020\u3002\u201D\n\u201C\u4E0D\u8FC7\uFF0C\u8981\u7EF4\u6301\u8FD9\u4E94\u5708\u5927\u9646\u59CB\u7EC8\u73AF\u7ED5\u7740\u5854\u8FD0\u8F6C\uFF0C\u9700\u8981\u5E9E\u5927\u7684\u80FD\u91CF\u3002\u8FD9\u5EA7\u5854\u65E0\u65F6\u65E0\u523B\u4E0D\u5728\u6D88\u8017\u80FD\u91CF\u3002\u201D\r\n\u201C\u800C\u6700\u8FD1\uFF0C\u6211\u53D1\u73B0\u7B2C\u4E00\u5927\u9646\u6240\u63D0\u4F9B\u7ED9\u5854\u7684\u80FD\u91CF\uFF0C\u5DF2\u7ECF\u4E0D\u8DB3\u4EE5\u540C\u65F6\u7EF4\u6301\u4E94\u5708\u5927\u9646\u4E86\u3002\u201D\n"
    isChoice: 0
    nextId: npc_12_2_8
    choices: []
  - id: npc_12_2_8
    timingKind: 4
