  - id: npc_2_2_2
    timingKind: 4
    backgroundId: NPC2/4
    characterId: Hero/1
    speakerName: "\u4F60"
    bodyText: "\u201C\u770B\u6765\u4F60\u7684\u9884\u8A00\u5E76\u4E0D\u51C6\u786E\u3002\u201D\n\u201C\u6211\u4EEC\u53C8\u89C1\u9762\u4E86\u3002\u8FD9\u6B21\u5148\u4E0D\u8BF4\u6211\uFF0C\u8BF4\u8BF4\u6709\u5173\u4F60\u7684\u4E8B\u60C5\u5427\u3002\u4F60\u662F\u7B2C\u4E00\u5927\u9646\u7684\u4EBA\u5417\uFF1F\u53C8\u4E3A\u4EC0\u4E48\u4F1A\u88AB\u675F\u7F1A\u5728\u8FD9\u91CC\uFF1F\u201D\n"
