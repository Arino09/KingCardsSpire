    backgroundId: NPC12/1
    characterId: 
    speakerName: 
    bodyText: "\u4F60\u63A8\u5F00\u5176\u4E2D\u4E00\u6247\u539F\u4F4F\u6C11\u7684\u623F\u95E8\u3002\r\n\u95E8\u540E\u5E76\u4E0D\u662F\u666E\u901A\u7684\u623F\u95F4\uFF0C\u800C\u662F\u4E00\u6761\u770B\u4E0D\u5230\u5C3D\u5934\u7684\u957F\u5ECA\u3002\u957F\u5ECA\u4E24\u4FA7\u6302\u7740\u660F\u9EC4\u7684\u58C1\u706F\uFF0C\u524D\u65B9\u4E0D\u8FDC\u5904\u6709\u4E00\u6247\u95E8\uFF0C\u770B\u8D77\u6765\u53EA\u8981\u518D\u8D70\u4E00\u6BB5\u8DEF\u5C31\u80FD\u5230\u8FBE\u3002\r\n\u4F60\u671D\u90A3\u6247\u95E8\u8D70\u53BB\u3002\r"
    isChoice: 0
