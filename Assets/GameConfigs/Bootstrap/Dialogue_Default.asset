  - id: npc_11_2_12
    timingKind: 4
    backgroundId: NPC11/3
    characterId: NPC/1_1
    speakerName: "\u56DA\u5F92"
    bodyText: "\u201C\u8FD9\u662F\u4E00\u4E2A\u4E13\u95E8\u5173\u62BC\u5E0C\u7FBD\u4EBA\u7684\u7262\u623F\u3002\u5728\u6211\u4E4B\u524D\uFF0C\u4E5F\u6709\u5F88\u591A\u5E0C\u7FBD\u4EBA\u88AB\u5173\u5728\u8FD9\u91CC\u3002\u201D\r\n\u201C\u5854\u628A\u6211\u4EEC\u7B2C\u4E94\u5927\u9646\u7684\u4EBA\u5F53\u6210\u7272\u755C\u4E00\u6837\u5708\u517B\u3002\u6BCF\u9694\u4E00\u6BB5\u65F6\u95F4\uFF0C\u5854\u5C31\u4F1A\u79FB\u52A8\u5230\u6211\u4EEC\u5927\u9646\u7684\u9644\u8FD1\uFF0C\u593A\u8D70\u6211\u4EEC\u7684\u79D1\u6280\u3001\u8D44\u6E90\u548C\u667A\u6167\u6210\u679C\uFF0C\u7136\u540E\u518D\u8BA9\u6211\u4EEC\u5931\u53BB\u8BB0\u5FC6\u3002\u8FD9\u6837\u4E00\u6765\uFF0C\u6211\u4EEC\u7684\u6587\u660E\u5C31\u6C38\u8FDC\u65E0\u6CD5\u8FDB\u6B65\u4E86\u3002\u201D"
    isChoice: 0
    nextId: npc_11_2_13
    choices: []
