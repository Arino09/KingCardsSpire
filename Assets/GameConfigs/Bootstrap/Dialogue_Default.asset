    characterId: 
    speakerName: "\u5EFA\u7B51\u5E08"
    bodyText: "\u201C\u800C\u90A3\u6247\u95E8\uFF0C\u5E76\u4E0D\u5728\u73AF\u7684\u5C3D\u5934\u3002\u201D\r\n\u201C\u5B83\u5728\u73AF\u7684\u4E2D\u95F4\u3002\u201D\n\u201C\u6240\u4EE5\uFF0C\u4E0D\u7BA1\u4F60\u8D70\u591A\u4E45\uFF0C\u90FD\u6C38\u8FDC\u5230\u4E0D\u4E86\u90A3\u91CC\u3002\u201D\n\u201C\u6211\u5DF2\u7ECF\u60F3\u597D\u4E86\u3002\u8FD9\u79CD\u5EFA\u7B51\uFF0C\u5C31\u53EB\u4F5C\u2014\u2014\u83AB\u6BD4\u4E4C\u65AF\u73AF\u3002\u201D\r\n\n"
    isChoice: 0
    nextId: 
    choices: []
  - id: npc_12_2_1
    timingKind: 4
    backgroundId: NPC12/4
    characterId: 
    speakerName: 
    bodyText: "\u4F60\u518D\u6B21\u6765\u5230\u5EFA\u7B51\u5E08\u7684\u623F\u95F4\u3002\r\n\u63A8\u5F00\u95E8\u7684\u77AC\u95F4\uFF0C\u773C\u524D\u7684\u666F\u8C61\u5374\u4E0E\u4E0A\u6B21\u622A\u7136\u4E0D\u540C\u3002\r\n\u4F60\u53D1\u73B0\u81EA\u5DF1\u6B63\u7AD9\u5728\u5854\u9876\u3002\u9AD8\u5904\u7684\u98CE\u4ECE\u8033\u8FB9\u547C\u5578\u800C\u8FC7\uFF0C\u4F60\u4F4E\u5934\u5411\u4E0B\u671B\u53BB\uFF0C\u53EA\u89C1\u4E00\u5708\u53C8\u4E00\u5708\u5DE8\u5927\u7684\u5927\u9646\u73AF\u7ED5\u7740\u9ED1\u5854\u7F13\u7F13\u5EF6\u4F38\u3002"
    isChoice: 0
    nextId: npc_12_2_2
    choices: []
