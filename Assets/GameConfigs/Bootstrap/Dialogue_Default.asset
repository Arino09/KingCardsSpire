    backgroundId: NPC4/6
    characterId: 
    speakerName: 
    bodyText: "\u4F60\u7AD9\u5728\u539F\u5730\uFF0C\u80F8\u53E3\u5FFD\u7136\u6D8C\u4E0A\u4E00\u9635\u83AB\u540D\u7684\u4E0D\u5B89\u3002\r\n\u4F60\u9690\u7EA6\u611F\u89C9\u5230\uFF0C\u8FD9\u91CC\u6709\u4E00\u4E2A\u4EBA\u75C5\u5F97\u5F88\u91CD\uFF0C\u5DF2\u7ECF\u5FEB\u8981\u6B7B\u4E86\u3002\r\n\u4E0B\u4E00\u523B\uFF0C\u4F60\u731B\u5730\u62AC\u8D77\u5934\uFF0C\u6574\u4E2A\u4EBA\u90FD\u50F5\u4F4F\u4E86\u3002\r\n\u75C5\u5E8A\u4E0A\u8EBA\u7740\u7684\u4EBA\uFF0C\u7ADF\u7136\u662F\u4F60\u81EA\u5DF1\u3002"
