  - id: npc_11_2_11
    timingKind: 4
    backgroundId: NPC11/3
    characterId: 
    speakerName: 
    bodyText: "\u53EF\u5899\u4E0A\u7684\u75D5\u8FF9\u8FDC\u4E0D\u6B626000\u9053\u3002\u4F60\u7C97\u7565\u4F30\u7B97\uFF0C\u81F3\u5C11\u6709\u6570\u5341\u4E07\u9053\u3002\u7537\u4EBA\u4F3C\u4E4E\u770B\u51FA\u4E86\u4F60\u7684\u7591\u60D1\uFF0C\u4ED6\u6380\u5F00\u94FA\u5728\u5730\u4E0A\u7684\u7A3B\u8349\uFF0C\u9732\u51FA\u4E0B\u9762\u4E00\u5C42\u53C8\u4E00\u5C42\u7D2F\u7D2F\u767D\u9AA8\u3002"
