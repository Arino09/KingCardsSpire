  - id: npc_2_1_1
    timingKind: 4
    backgroundId: NPC2/1
    characterId: 
    speakerName: 
    bodyText: "\u4F60\u63A8\u5F00\u5176\u4E2D\u4E00\u6247\u539F\u4F4F\u6C11\u7684\u623F\u95E8\u3002\r\n\u623F\u95F4\u91CC\u9759\u5F97\u51FA\u5947\u3002\u4E00\u4E2A\u53CC\u773C\u7F20\u7740\u9ED1\u5E03\u7684\u5973\u5B69\u5B89\u9759\u5730\u5750\u5728\u5706\u684C\u65C1\uFF0C\u684C\u4E0A\u6446\u7740\u4E00\u9897\u5E7D\u5E7D\u6CDB\u5149\u7684\u6C34\u6676\u7403\u3002\n\u4F60\u4E0B\u610F\u8BC6\u5730\u671B\u5411\u90A3\u9897\u6C34\u6676\u7403\uFF0C\u6070\u597D\u5728\u5176\u4E2D\u770B\u89C1\u4E86\u81EA\u5DF1\u5012\u6620\u7684\u9762\u5BB9\u3002"
    isChoice: 0
    nextId: npc_2_1_2
    choices: []
