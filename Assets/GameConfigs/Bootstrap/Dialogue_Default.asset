    speakerName: 
    bodyText: "\u591A\u5E74\u540E\uFF0C\u4E94\u7247\u5927\u9646\u4E0D\u518D\u5F7C\u6B64\u9694\u7EDD\u3002\r\n\u5854\u7684\u8DC3\u8FC1\u7CFB\u7EDF\u88AB\u6539\u9020\u6210\u516C\u5F00\u7684\u901A\u9053\uFF0C\u6587\u660E\u4E0E\u77E5\u8BC6\u5F00\u59CB\u81EA\u7531\u6D41\u52A8\uFF0C\u4E0D\u518D\u5C5E\u4E8E\u67D0\u4E00\u7247\u5927\u9646\u3002\r\n\u518D\u540E\u6765\uFF0C\u4E94\u5927\u9646\u7684\u4EBA\u4EEC\u5171\u540C\u8FC1\u5C45\u5230\u5176\u4E2D\u4E00\u7247\u6700\u5E7F\u9614\u7684\u571F\u5730\u4E0A\u3002"
