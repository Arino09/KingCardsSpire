    timingKind: 4
    backgroundId: NPC11/3
    characterId: 
    speakerName: 
    bodyText: "\u7537\u4EBA\u8F6C\u8FC7\u8EAB\uFF0C\u793A\u610F\u4F60\u8D70\u8FD1\u5899\u58C1\u3002\u539F\u6765\uFF0C\u5899\u4E0A\u523B\u7740\u4E00\u4E2A\u53C8\u4E00\u4E2A\u201C\u6B63\u201D\u5B57\uFF0C\u5BC6\u5BC6\u9EBB\u9EBB\u5730\u94FA\u6EE1\u4E86\u6574\u6574\u4E09\u9762\u5899\u3002\n"
