  - id: npc_4_2_1
    timingKind: 4
    backgroundId: NPC4/5
    characterId: 
    speakerName: 
    bodyText: "\u4F60\u518D\u6B21\u63A8\u5F00\u90A3\u6247\u623F\u95E8\u3002\u8FD9\u4E00\u6B21\uFF0C\u6E38\u4E50\u56ED\u6D88\u5931\u4E86\u3002\r\n\r\u6620\u5165\u773C\u5E18\u7684\uFF0C\u662F\u4E00\u95F4\u60E8\u767D\u800C\u51B0\u51B7\u7684\u533B\u9662\u3002\u8D70\u5ECA\u4E0A\u4EBA\u6765\u4EBA\u5F80\uFF0C\u811A\u6B65\u58F0\u3001\u63A8\u8F66\u58F0\u3001\u4F4E\u4F4E\u7684\u4EA4\u8C08\u58F0\u6DF7\u5728\u4E00\u8D77\uFF0C\u5608\u6742\u5F97\u8BA9\u4EBA\u5FC3\u70E6\u3002\u53EF\u548C\u4E0A\u4E00\u6B21\u4E00\u6837\uFF0C\u8FD9\u91CC\u6240\u6709\u4EBA\u7684\u9762\u5BB9\u90FD\u662F\u6A21\u7CCA\u7684\uFF0C\u50CF\u4E00\u7FA4\u6CA1\u6709\u4E94\u5B98\u7684\u5F71\u5B50\u3002"
