  m_Name: Dialogue_Default
  m_EditorClassIdentifier: 
  lines:
  - id: tutorial_opening
    timingKind: 1
    backgroundId: first1
    characterId: 
    speakerName: 
    bodyText: "\u6211\u51FA\u751F\u4E8E\u8FD9\u7247\u571F\u5730\u3002\r\n\u81EA\u8BB0\u4E8B\u8D77\uFF0C\u6BCF\u9694\u4E00\u6BB5\u65F6\u95F4\uFF0C\u5929\u9645\u5C3D\u5934\u5C31\u4F1A\u51FA\u73B0\u4E00\u5EA7\u9ED1\u8272\u9AD8\u5854\u3002\r\n\u5B83\u603B\u662F\u9759\u9759\u5730\u7ACB\u5728\u90A3\u91CC\uFF0C\u770B\u5F97\u89C1\uFF0C\u5374\u6C38\u8FDC\u65E0\u6CD5\u9760\u8FD1\u3002"
    isChoice: 0
    nextId: tutorial_opening_2
    choices: []
  - id: tutorial_opening_2
    timingKind: 1
    backgroundId: first1
    characterId: 
    speakerName: 
    bodyText: "\u591A\u5E74\u524D\uFF0C\u6709\u4E00\u4F4D\u65C5\u884C\u8005\u66FE\u8BD5\u56FE\u8BC1\u660E\u8FD9\u7247\u571F\u5730\u7684\u5F62\u72B6\u3002\r\n\u4ED6\u4ECE\u592A\u9633\u5347\u8D77\u7684\u5730\u65B9\u4E00\u76F4\u5411\u524D\u8D70\uFF0C\u4E09\u5929\u540E\uFF0C\u7ADF\u53C8\u56DE\u5230\u4E86\u51FA\u53D1\u7684\u539F\u70B9\u3002\r\n\u53EF\u90A3\u5EA7\u9AD8\u5854\uFF0C\u59CB\u7EC8\u505C\u7559\u5728\u4ED6\u7684\u53F3\u524D\u65B9\u3002\r\n\u65E0\u8BBA\u4ED6\u600E\u4E48\u8D70\uFF0C\u90FD\u65E0\u6CD5\u62B5\u8FBE\u3002"
    isChoice: 0
    nextId: tutorial_opening_3
    choices: []
  - id: tutorial_opening_3
    timingKind: 1
    backgroundId: first1
    characterId: 
    speakerName: 
    bodyText: "\u66F4\u8BE1\u5F02\u7684\u662F\uFF0C\u6BCF\u5F53\u9AD8\u5854\u51FA\u73B0\uFF0C\u6240\u6709\u4EBA\u90FD\u4F1A\u5931\u53BB\u4E00\u90E8\u5206\u8BB0\u5FC6\u3002\r\n\u5173\u4E8E\u5B83\u672C\u8EAB\u548C\u5B83\u51FA\u73B0\u540E\u7684\u4E8B\uFF0C\u6700\u540E\u90FD\u4F1A\u53D8\u5F97\u6A21\u7CCA\u4E0D\u6E05\u3002\r\n\u8FD9\u4E48\u591A\u5E74\u6765\uFF0C\u4F60\u8BD5\u8FC7\u65E0\u6570\u529E\u6CD5\uFF0C\u5374\u59CB\u7EC8\u627E\u4E0D\u5230\u90A3\u5EA7\u5854\u771F\u6B63\u7684\u4F4D\u7F6E\u3002\r\n\u76F4\u5230\u6709\u4E00\u5929\uFF0C\u4F60\u6536\u5230\u4E86\u4E00\u5C01\u6765\u81EA\u201C\u5854\u201D\u7684\u9080\u8BF7\u51FD\u3002"
    isChoice: 0
    nextId: tutorial_opening_4
    choices: []
  - id: tutorial_opening_4
    timingKind: 1
    backgroundId: first2
    characterId: 
    speakerName: 
    bodyText: "\u9274\u4E8E\u60A8\u5728\u7B2C\u4E94\u5927\u9646\u7684\u4F18\u5F02\u8868\u73B0\uFF0C\u6211\u4EEC\u8BDA\u631A\u9080\u8BF7\u60A8\u6210\u4E3A\u201C\u4E16\u754C\u201D\u7BA1\u7406\u8005\u7684\u4E00\u5458\u3002\n\u5982\u6709\u610F\u52A0\u5165\uFF0C\u8BF7\u5728\u9080\u8BF7\u51FD\u4E0B\u65B9\u7B7E\u5B57\u3002\r\n\r\u5728\u6B64\u4E4B\u524D\uFF0C\u60A8\u8FD8\u9700\u8981\u901A\u8FC7\u4E00\u4E9B\u6D4B\u8BD5\uFF0C\u4EE5\u8BC1\u660E\u81EA\u5DF1\u7684\u80FD\u529B\u3002\u82E5\u4E0D\u5E78\u88AB\u6DD8\u6C70\uFF0C\u4E5F\u9700\u627F\u62C5\u76F8\u5E94\u7684\u4EE3\u4EF7\u3002\r\n\r\u6765\u81EA\u201C\u4E16\u754C\u201D\u7BA1\u7406\u8005\u59D4\u5458\u4F1A"
    isChoice: 0
    nextId: tutorial_opening_5
    choices: []
  - id: tutorial_opening_5
    timingKind: 1
    backgroundId: first3
    characterId: 
    speakerName: 
    bodyText: "\u548C\u9080\u8BF7\u51FD\u4E00\u8D77\u9001\u6765\u7684\uFF0C\u8FD8\u6709\u4E09\u5F20\u5361\u724C\u3002\r\n\u4E00\u5F20\u662F\u5934\u6234\u738B\u51A0\u7684\u8001\u8005\u3002\r\n\u4E00\u5F20\u662F\u8EAB\u7740\u534E\u670D\u7684\u4E2D\u5E74\u7537\u4EBA\u3002\r\n\u8FD8\u6709\u4E00\u5F20\uFF0C\u662F\u8863\u886B\u8934\u891B\u7684\u5B69\u7AE5\u3002"
    isChoice: 0
    nextId: tutorial_opening_6
    choices: []
  - id: tutorial_opening_6
    timingKind: 1
    backgroundId: first3
    characterId: 
    speakerName: 
    bodyText: "\u4F5C\u4E3A\u5E0C\u7FBD\u56FD\u7684\u7B2C\u4E00\u4FA6\u63A2\uFF0C\u4F60\u6709\u8D23\u4EFB\u67E5\u6E05\u201C\u5854\u201D\u7684\u771F\u76F8\u3002\r\n\u4E0D\u8BA1\u4EE3\u4EF7\u3002\r\n\u4F60\u6CA1\u6709\u72B9\u8C6B\uFF0C\u5728\u9080\u8BF7\u51FD\u4E0B\u7B7E\u4E0B\u4E86\u81EA\u5DF1\u7684\u540D\u5B57\u3002"
    isChoice: 0
    nextId: tutorial_opening_7
    choices: []
  - id: tutorial_opening_7
    timingKind: 1
    backgroundId: first4
    characterId: 
    speakerName: 
    bodyText: "\u4E0B\u4E00\u77AC\uFF0C\u773C\u524D\u7684\u666F\u8C61\u9AA4\u7136\u626D\u66F2\u3002\r\n\u7B49\u4F60\u56DE\u8FC7\u795E\u6765\uFF0C\u81EA\u5DF1\u5DF2\u7ECF\u7AD9\u5728\u4E00\u6247\u9ED1\u8272\u5DE8\u95E8\u524D\u3002\r\n\u4F60\u7F13\u7F13\u62AC\u8D77\u5934\u3002\u95E8\u540E\u9AD8\u8038\u5165\u5929\u7684\uFF0C\u6B63\u662F\u90A3\u5EA7\u9ED1\u8272\u9AD8\u5854\u3002\r\n\"\u5B8C\u5168\u6CA1\u610F\u8BC6\u5230\u53D1\u751F\u4E86\u4EC0\u4E48\u2026\u2026\u6211\u5C45\u7136\u5DF2\u7ECF\u5230\u5854\u4E0B\u4E86\uFF1F\""
    isChoice: 0
    nextId: tutorial_opening_8
    choices: []
  - id: tutorial_opening_8
    timingKind: 1
    backgroundId: first5
    characterId: 
    speakerName: 
    bodyText: "\u4F60\u73AF\u987E\u56DB\u5468\u3002\u9AD8\u5854\u77D7\u7ACB\u5728\u4E00\u7247\u7A7A\u65F7\u7684\u5E7F\u573A\u4E2D\u592E\uFF0C\u56DB\u5468\u95EA\u70C1\u7740\u6E5B\u84DD\u8272\u7684\u5149\u8292\u3002\r\n\r\u66F4\u9AD8\u5904\u7684\u5929\u7A7A\u4E2D\uFF0C\u5076\u5C14\u6709\u5DE8\u5927\u7684\u8239\u4F53\u98DE\u9A70\u800C\u8FC7\u3002\r\n\u8FD8\u6CA1\u7B49\u4F60\u770B\u6E05\u8FD9\u4E00\u5207\uFF0C\u8EAB\u65C1\u5FFD\u7136\u95EA\u8FC7\u4E00\u9053\u5149\u5F71\u3002\r\n\u4E00\u4E2A\u964C\u751F\u7684\u5973\u4EBA\u51FA\u73B0\u5728\u4F60\u8EAB\u8FB9\u3002"
    isChoice: 0
    nextId: tutorial_opening_9
    choices: []
  - id: tutorial_opening_9
    timingKind: 1
    backgroundId: first5
    characterId: 
    speakerName: "\u94C3\u5B50"
    bodyText: "\u201C\u4F60\u597D\uFF0C\u770B\u6837\u5B50\u4F60\u4E5F\u662F\u8FD9\u6B21\u7ADE\u9009\u7684\u53C2\u8D5B\u8005\u3002\n\u6211\u662F\u6765\u81EA\u7B2C\u4E8C\u5927\u9646\u7684\u94C3\u5B50\u3002\u5982\u679C\u7B49\u4F1A\u513F\u8FDB\u4E86\u5854\uFF0C\u6211\u4EEC\u6709\u673A\u4F1A\u5408\u4F5C\u7684\u8BDD\uFF0C\u6211\u5F88\u8363\u5E78\u3002\u201D"
    isChoice: 0
    nextId: tutorial_opening_10
    choices: []
  - id: tutorial_opening_10
    timingKind: 1
    backgroundId: first5
    characterId: 
    speakerName: "\u4F60"
    bodyText: "\u201C\u4F60\u597D\uFF0C\u6211\u662F\u6765\u81EA\u7B2C\u4E94\u5927\u9646\u7684\u98CE\u95F4\u3002\n\u4E0D\u8FC7\u5728\u90A3\u4E4B\u524D\uFF0C\u6211\u60F3\u5148\u95EE\u4E00\u53E5\u2026\u2026\u8FD9\u4E2A\u2018\u7B2C\u51E0\u5927\u9646\u2019\uFF0C\u8FD8\u6709\u4F60\u8BF4\u7684\u2018\u4E16\u754C\u2019\uFF0C\u5230\u5E95\u662F\u4EC0\u4E48\u610F\u601D\uFF1F\u201D"
    isChoice: 0
    nextId: tutorial_opening_11
    choices: []
  - id: tutorial_opening_11
    timingKind: 1
    backgroundId: first5
    characterId: 
    speakerName: "\u94C3\u5B50"
    bodyText: "\u201C\u7B2C\u4E94\u5927\u9646\u5417\uFF1F\u96BE\u602A\u4F60\u4EC0\u4E48\u90FD\u4E0D\u77E5\u9053\u3002\r\n\u89E3\u91CA\u8D77\u6765\u6709\u70B9\u957F\u3002\u7B49\u4F60\u8FDB\u5854\u4EE5\u540E\uFF0C\u81EA\u7136\u4F1A\u6709\u4EBA\u544A\u8BC9\u4F60\u3002\r\r\n\u4F60\u73B0\u5728\u811A\u4E0B\u7AD9\u7740\u7684\u5730\u65B9\uFF0C\u662F\u7B2C\u4E00\u5927\u9646\u7684\u4E2D\u5FC3\u3002\r\n\u800C\u2018\u4E16\u754C\u2019\uFF0C\u5C31\u662F\u8FD9\u5EA7\u5854\u7684\u540D\u5B57\u3002\u201D"
    isChoice: 0
    nextId: tutorial_opening_12
    choices: []
  - id: tutorial_opening_12
    timingKind: 1
    backgroundId: first6
    characterId: 
    speakerName: 
    bodyText: "\u9AD8\u5854\u7684\u5927\u95E8\u7F13\u7F13\u6253\u5F00\u3002\u4F60\u548C\u94C3\u5B50\u4E00\u540C\u8D70\u8FDB\u5854\u5185\u3002\r\n\r\u5927\u6BBF\u4E2D\u592E\u6446\u7740\u4E00\u5F20\u957F\u684C\uFF0C\u4E0D\u8FDC\u5904\uFF0C\u4E00\u4E2A\u5C11\u5973\u548C\u4E00\u4E2A\u5927\u53D4\u6B63\u7AD9\u5728\u684C\u5B50\u4E24\u4FA7\uFF0C\u624B\u91CC\u6446\u5F04\u7740\u5361\u724C\u3002\r\n\u90A3\u51E0\u5F20\u5361\uFF0C\u770B\u8D77\u6765\u548C\u4F60\u6536\u5230\u7684\u4E00\u6A21\u4E00\u6837\u3002\r\n\u4F60\u521A\u8D70\u8FD1\uFF0C\u5C31\u770B\u89C1\u4E24\u4EBA\u5404\u81EA\u6263\u4E0B\u4E86\u4E00\u5F20\u724C\u3002"
    isChoice: 0
    nextId: tutorial_opening_13
    choices: []
  - id: tutorial_opening_13
    timingKind: 1
    backgroundId: first6
    characterId: Boss/1
    speakerName: "\u62AB\u7740\u6597\u7BF7\u7684\u7537\u4EBA"
    bodyText: "\u201C\u54DF\uFF0C\u8FD9\u4E48\u5FEB\u5C31\u5F00\u59CB\u6559\u65B0\u4EBA\u4E86\uFF0C\u82B1\u3002\u201D"
    isChoice: 0
    nextId: tutorial_opening_14
    choices: []
  - id: tutorial_opening_14
    timingKind: 1
    backgroundId: first6
    characterId: 
    speakerName: 
    bodyText: "\u4E0D\u77E5\u4F55\u65F6\uFF0C\u4E00\u4E2A\u62AB\u7740\u6597\u7BF7\u7684\u7537\u4EBA\u5DF2\u7ECF\u7AD9\u5728\u684C\u65C1\uFF0C\u6B63\u770B\u7740\u90A3\u540D\u5C11\u5973\u3002\r\n\u5C11\u5973\u6CA1\u6709\u7406\u4F1A\u4ED6\uFF0C\u53EA\u662F\u62AC\u624B\u7FFB\u5F00\u4E86\u81EA\u5DF1\u7684\u5361\u724C\u3002\r\n\u90A3\u6B63\u662F\u4F60\u624B\u91CC\u7684\u90A3\u5F20\u2014\u2014\u8863\u886B\u8934\u891B\u7684\u5B69\u7AE5\u3002\r\n\u5927\u53D4\u4E5F\u968F\u5373\u7FFB\u5F00\u81EA\u5DF1\u7684\u724C\u3002\u724C\u9762\u4E0A\uFF0C\u662F\u90A3\u540D\u5934\u6234\u738B\u51A0\u7684\u8001\u8005\u3002\r"
    isChoice: 0
    nextId: tutorial_opening_15
    choices: []
  - id: tutorial_opening_15
    timingKind: 1
    backgroundId: first7
    characterId: 
    speakerName: "\u5927\u53D4"
    bodyText: "\u201C\u8FD0\u6C14\u771F\u597D\uFF0C\u4F60\u8D62\u4E86\u3002\u201D"
    isChoice: 0
    nextId: tutorial_opening_16
    choices: []
  - id: tutorial_opening_16
    timingKind: 1
    backgroundId: first7
    characterId: Boss/1
    speakerName: "\u62AB\u7740\u6597\u7BF7\u7684\u7537\u4EBA"
    bodyText: "\u6B63\u597D\uFF0C\u8D81\u8FD9\u4E2A\u673A\u4F1A\uFF0C\u6211\u6765\u7ED9\u65B0\u4EBA\u8BB2\u8BB2\u5854\u91CC\u7684\u89C4\u5219\u3002\r\n\u4F60\u4EEC\u90FD\u662F\u672C\u6B21\u4E16\u754C\u7BA1\u7406\u8005\u7ADE\u9009\u7684\u53C2\u8D5B\u8005\uFF0C\u4E5F\u662F\u5404\u81EA\u5927\u9646\u4E2D\u6700\u4F18\u79C0\u7684\u4EBA\u3002\r\n\u800C\u73B0\u5728\u6240\u5728\u7684\u4F4D\u7F6E\uFF0C\u662F\u4E16\u754C\u4E4B\u5854\u7684\u7B2C\u4E00\u5C42\u3002\u60F3\u7EE7\u7EED\u5F80\u4E0A\u8D70\uFF0C\u65B9\u6CD5\u5F88\u7B80\u5355\u2014\u2014\u8D62\u3002\r\n\r\u80DC\u8D1F\uFF0C\u5C06\u901A\u8FC7\u5361\u724C\u5BF9\u5F08\u51B3\u5B9A\u3002\r"
    isChoice: 0
    nextId: tutorial_opening_17
    choices: []
  - id: tutorial_opening_17
    timingKind: 1
    backgroundId: first8
    characterId: 
    speakerName: "\u62AB\u7740\u6597\u7BF7\u7684\u7537\u4EBA"
    bodyText: "\r\u6BCF\u4E2A\u4EBA\u6700\u521D\u90FD\u4F1A\u62E5\u6709\u4E09\u5F20\u57FA\u7840\u724C\uFF1A\u56FD\u738B\u3001\u5927\u81E3\u3001\u5E73\u6C11\u3002\r\n\u56FD\u738B\u7B49\u7EA7\u6700\u9AD8\uFF0C\u5927\u81E3\u6B21\u4E4B\uFF0C\u5E73\u6C11\u6700\u4F4E\u3002\u9AD8\u7B49\u7EA7\u53EF\u4EE5\u51FB\u8D25\u4F4E\u7B49\u7EA7\uFF0C\u4F46\u5E73\u6C11\u53EF\u4EE5\u53CD\u8FC7\u6765\u514B\u5236\u56FD\u738B\u3002\n\u6CA1\u9519\uFF0C\u8FD9\u5C31\u662F\u6700\u7ECF\u5178\u7684\u6E38\u620F\u2014\u2014\u77F3\u5934\u526A\u5200\u5E03\u3002"
    isChoice: 0
    nextId: tutorial_opening_18
    choices: []
  - id: tutorial_opening_18
    timingKind: 1
    backgroundId: first8
    characterId: 
    speakerName: "\u62AB\u7740\u6597\u7BF7\u7684\u7537\u4EBA"
    bodyText: "\u8F93\u6389\u7684\u724C\uFF0C\u4F1A\u8FDB\u5165\u5F03\u724C\u5806\uFF0C\u672C\u5C40\u4E0D\u80FD\u518D\u6B21\u4F7F\u7528\u3002\n\u5F53\u4E00\u65B9\u6CA1\u6709\u724C\u53EF\u51FA\u65F6\uFF0C\u5C31\u7B97\u5931\u8D25\u3002\u9664\u6B64\u4E4B\u5916\uFF0C\u6211\u4EEC\u8FD8\u52A0\u4E86\u4E24\u6761\u89C4\u5219\u3002\r\n\r\r\u7B2C\u4E00\uFF0C\u4E0D\u80FD\u8FDE\u7EED\u4E24\u6B21\u6253\u51FA\u540C\u4E00\u5F20\u724C\u3002\r\n\u7B2C\u4E8C\uFF0C\u5F53\u56DE\u5408\u6570\u8FBE\u5230\u53CC\u65B9\u521D\u59CB\u5361\u724C\u603B\u6570\u7684\u4E00\u534A\u65F6\u5BF9\u5C40\u7ED3\u675F\u3002\u53CC\u65B9\u5269\u4F59\u5361\u724C\u7B49\u7EA7\u603B\u548C\u66F4\u4F4E\u7684\u4E00\u65B9\u83B7\u80DC\u3002\r\r"
    isChoice: 0
    nextId: tutorial_opening_19
    choices: []
  - id: tutorial_opening_19
    timingKind: 1
    backgroundId: first8
