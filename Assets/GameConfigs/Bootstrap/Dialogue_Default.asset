    speakerName: "\u56DA\u5F92"
    bodyText: "\u201C\u542C\u6211\u8BF4\uFF0C\u5B69\u5B50\u3002\u6211\u4E5F\u6765\u81EA\u5E0C\u7FBD\u56FD\uFF0C\u4E5F\u66FE\u662F\u53C2\u8D5B\u8005\u3002\u73B0\u5728\uFF0C\u6211\u6050\u6015\u5DF2\u7ECF\u662F\u5854\u5185\u6D3B\u7740\u7684\u6700\u540E\u4E00\u4E2A\u5E0C\u7FBD\u4EBA\u4E86\u3002\u5854\u91CC\u7684\u9AD8\u5C42\u6839\u672C\u4E0D\u53EF\u80FD\u8BA9\u6211\u4EEC\u7B2C\u4E94\u5927\u9646\u7684\u4EBA\u6210\u4E3A\u7BA1\u7406\u8005\uFF0C\u8FD9\u4ECE\u5934\u5230\u5C3E\u5C31\u662F\u4E00\u4E2A\u9A97\u5C40\u3002\u4F60\u5FEB\u79BB\u5F00\u5427\uFF0C\u5343\u4E07\u4E0D\u8981\u548C\u9A7B\u5B88\u8005\u5BF9\u5F08\uFF0C\u4F60\u6839\u672C\u627F\u53D7\u4E0D\u8D77\u90A3\u79CD\u4EE3\u4EF7\u3002\u201D"
