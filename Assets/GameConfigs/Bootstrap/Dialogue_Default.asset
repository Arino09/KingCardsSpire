    speakerName: 
    bodyText: "\u4ED6\u62AC\u8D77\u624B\uFF0C\u8F7B\u8F7B\u6307\u4E86\u6307\u4F60\u7684\u5934\u9876\u3002\r\n\u201C\u5728\u8FD9\u91CC\u54E6\u3002\u201D\r\n\u4F60\u4F38\u624B\u4E00\u6478\uFF0C\u82F9\u679C\u7ADF\u771F\u7684\u51FA\u73B0\u5728\u4E86\u4F60\u7684\u5934\u4E0A\u3002\r\n\u4E0B\u4E00\u523B\uFF0C\u4F60\u4E0D\u53D7\u63A7\u5236\u5730\u7B11\u4E86\u8D77\u6765\u3002\u90A3\u7B11\u58F0\u8D8A\u6765\u8D8A\u5927\uFF0C\u8FDE\u4F60\u81EA\u5DF1\u90FD\u505C\u4E0D\u4E0B\u6765\u3002\r"
