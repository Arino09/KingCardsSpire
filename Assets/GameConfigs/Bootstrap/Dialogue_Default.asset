    timingKind: 4
    backgroundId: NPC12/5
    characterId: 
    speakerName: 
    bodyText: "\u5EFA\u7B51\u5E08\u6D88\u5931\u4E86\u3002\u8FDE\u540C\u4ED6\u7684\u623F\u95F4\u4E00\u8D77\u3002"
