    choices: []
  - id: npc_12_1_2
    timingKind: 4
    backgroundId: NPC12/1
    characterId: 
    speakerName: 
    bodyText: "\u53EF\u8D70\u4E86\u8BB8\u4E45\uFF0C\u90A3\u6247\u95E8\u4F9D\u65E7\u505C\u5728\u539F\u5904\uFF0C\u50CF\u662F\u59CB\u7EC8\u4E0E\u4F60\u9694\u7740\u540C\u6837\u7684\u8DDD\u79BB\u3002\u65E0\u8BBA\u4F60\u600E\u4E48\u52A0\u5FEB\u811A\u6B65\uFF0C\u90FD\u65E0\u6CD5\u771F\u6B63\u9760\u8FD1\u5B83\u3002\r\n\u5C31\u5728\u8FD9\u65F6\uFF0C\u4F60\u8EAB\u540E\u4F20\u6765\u4E00\u9053\u58F0\u97F3\u3002"
