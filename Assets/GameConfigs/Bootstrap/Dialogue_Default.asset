    speakerName: 
    bodyText: "\u4F60\u518D\u6B21\u8D70\u8FDB\u623F\u95F4\u65F6\uFF0C\u90A3\u540D\u5E0C\u7FBD\u4EBA\u5DF2\u7ECF\u4E0D\u77E5\u6240\u8E2A\u3002\r\n\u4F60\u8D70\u8FD1\u5899\u58C1\uFF0C\u53D1\u73B0\u6700\u540E\u4E00\u4E2A\u201C\u6B63\u201D\u5B57\u540E\u9762\uFF0C\u523B\u7740\u56DB\u4E2A\u5D2D\u65B0\u7684\u5B57\u2014\u2014\r\n\u201C\u6C38\u4E0D\u653E\u5F03\u201D\r\n\u5728\u5899\u58C1\u7684\u4E0B\u65B9\u653E\u7740\u4E00\u5F20\u5361\u724C\u3002"
