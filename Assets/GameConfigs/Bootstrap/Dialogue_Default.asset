    backgroundId: NPC2/4
    characterId: 
    speakerName: 
    bodyText: "\u7B2C\u4E00\u6B21\u89C1\u9762\u65F6\uFF0C\u4F60\u66FE\u5077\u5077\u4F7F\u7528\u8FC7\u3010\u89C6\u754C\u9650\xB7\u89E3\u3011\u3002\r\n\u90A3\u4E00\u77AC\u95F4\uFF0C\u4F60\u6E05\u695A\u5730\u770B\u89C1\uFF0C\u5979\u684C\u4E0B\u7684\u53CC\u811A\uFF0C\u6B63\u88AB\u51B0\u51B7\u7684\u9563\u94D0\u7262\u7262\u9501\u4F4F\u3002\n\u5973\u5B69\u6C89\u9ED8\u4E86\u7247\u523B\uFF0C\u4F3C\u4E4E\u5E76\u4E0D\u610F\u5916\u4F60\u4F1A\u95EE\u8D77\u8FD9\u4E9B\u3002"
    isChoice: 0
    nextId: npc_2_2_4
    choices: []
  - id: npc_2_2_4
    timingKind: 4
