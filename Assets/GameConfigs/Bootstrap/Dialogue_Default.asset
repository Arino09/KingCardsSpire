    speakerName: "\u5EFA\u7B51\u5E08"
    bodyText: "\u201C\u4F60\u53EF\u4EE5\u53EB\u6211\u5EFA\u7B51\u5E08\u3002\u201D\n\u201C\u600E\u4E48\u6837\uFF0C\u53CD\u6297\u8005\uFF0C\u4F60\u89C9\u5F97\u6211\u8BBE\u8BA1\u7684\u5EFA\u7B51\u5982\u4F55\uFF1F\u201D\n"
