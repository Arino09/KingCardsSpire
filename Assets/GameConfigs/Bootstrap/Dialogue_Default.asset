    speakerName: "\u5360\u535C\u5E08"
    bodyText: "\u201C\u6211\u662F\u8FD9\u4E00\u5C42\u9A7B\u5B88\u8005\u7684\u5973\u513F\u3002\u201D\n\u5979\u7684\u58F0\u97F3\u4F9D\u65E7\u5F88\u8F7B\uFF0C\n\u201C\u6211\u51FA\u751F\u4E8E\u5343\u5E74\u524D\u7684\u7B2C\u4E00\u5927\u9646\u3002\u90A3\u4E2A\u65F6\u5019\uFF0C\u6574\u4E2A\u4E16\u754C\u8FD8\u53EA\u6709\u8FD9\u4E00\u7247\u9646\u5730\u3002\u201D\n"
