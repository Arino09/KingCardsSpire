    speakerName: 
    bodyText: "\u4F60\u63A8\u5F00\u5176\u4E2D\u4E00\u6247\u539F\u4F4F\u6C11\u7684\u623F\u95E8\u3002\u4E0B\u4E00\u523B\uFF0C\u56DB\u5468\u9AA4\u7136\u660E\u4EAE\u8D77\u6765\u3002\r\n\r\u4F60\u53D1\u73B0\u81EA\u5DF1\u6B63\u7AD9\u5728\u4E00\u5EA7\u70ED\u95F9\u7684\u6E38\u4E50\u56ED\u91CC\u3002\u5F69\u706F\u4E00\u6392\u6392\u4EAE\u7740\uFF0C\u8FDC\u5904\u7684\u65CB\u8F6C\u6728\u9A6C\u7F13\u7F13\u8F6C\u52A8\u3002\n\u8857\u9053\u4E0A\u6324\u6EE1\u4E86\u6765\u6765\u5F80\u5F80\u7684\u6E38\u5BA2\uFF0C\u53EF\u4ED6\u4EEC\u7684\u9762\u5BB9\u5374\u90FD\u6A21\u7CCA\u4E0D\u6E05\uFF0C\u50CF\u4E00\u7FA4\u88AB\u968F\u610F\u6D82\u62B9\u51FA\u6765\u7684\u5F71\u5B50\u3002\r\r"
