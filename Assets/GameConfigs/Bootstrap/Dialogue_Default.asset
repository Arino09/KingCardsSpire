  - id: npc_11_2_10
    timingKind: 4
    backgroundId: NPC11/3
    characterId: NPC/1_1
    speakerName: "\u56DA\u5F92"
    bodyText: "\u201C\u7B97\u4E0A\u4ECA\u5929\uFF0C\u6211\u5DF2\u7ECF\u5728\u8FD9\u91CC\u5F85\u4E865964\u5929\u3002\u5899\u4E0A\u7684\u75D5\u8FF9\uFF0C\u8BB0\u5F55\u7740\u6211\u88AB\u56DA\u7981\u5728\u8FD9\u91CC\u7684\u65F6\u95F4\uFF0C\u4E5F\u662F\u5728\u63D0\u9192\u6211\u81EA\u5DF1\uFF0C\u6C38\u8FDC\u4E0D\u8981\u5931\u53BB\u53CD\u6297\u7684\u5FF5\u5934\u3002\u201D"
