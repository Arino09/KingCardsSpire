  - id: npc_12_3_1
    timingKind: 4
    backgroundId: NPC12/5
    characterId: 
    speakerName: 
    bodyText: "\u4F60\u518D\u6B21\u6765\u5230\u5EFA\u7B51\u5E08\u539F\u672C\u6240\u5728\u7684\u4F4D\u7F6E\u3002\r\n\u53EF\u8FD9\u4E00\u6B21\uFF0C\u90A3\u91CC\u5DF2\u7ECF\u4E0D\u518D\u6709\u95E8\u4E86\u3002\r\n\u539F\u672C\u901A\u5F80\u623F\u95F4\u7684\u5165\u53E3\uFF0C\u5982\u4ECA\u53EA\u5269\u4E0B\u4E00\u9762\u5B8C\u6574\u800C\u51B0\u51B7\u7684\u77F3\u5899\uFF0C\u4EFF\u4F5B\u90A3\u6761\u957F\u5ECA\u4ECE\u672A\u5B58\u5728\u8FC7\u3002\r\r\r\n"
    isChoice: 0
    nextId: npc_12_3_2
    choices: []
