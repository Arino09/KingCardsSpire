    speakerName: 
    bodyText: "\u5E8A\u8FB9\u7AD9\u7740\u4E00\u540D\u533B\u751F\uFF0C\u6B63\u4F4E\u5934\u770B\u7740\u4F60\u3002\n\u201C\u4F60\u8BE5\u5403\u836F\u4E86\u3002\u201D\r\n\u201C\u5403\u4E86\u836F\uFF0C\u5C31\u4F1A\u597D\u8D77\u6765\u7684\u3002\u201D\n"
