    speakerName: 
    bodyText: "\u4F60\u4E0B\u610F\u8BC6\u56DE\u5934\uFF0C\u6765\u65F6\u7684\u95E8\u5DF2\u7ECF\u4E0D\u89C1\u4E86\u3002\r\n\u5C31\u5728\u4E0D\u8FDC\u5904\uFF0C\u4EBA\u7FA4\u56F4\u6210\u4E86\u4E00\u4E2A\u5708\u3002\r\n\u5708\u5B50\u7684\u4E2D\u592E\uFF0C\u4E00\u4E2A\u7A7F\u7740\u5DE8\u5927\u73A9\u5076\u670D\u7684\u5C0F\u4E11\u6B63\u5728\u5356\u529B\u5730\u8868\u6F14\u3002\r\r"
