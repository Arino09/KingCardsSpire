    speakerName: "\u5EFA\u7B51\u5E08"
    bodyText: "\u4F60\u5F88\u5FEB\u4FBF\u5728\u7B2C\u4E94\u5708\u770B\u89C1\u4E86\u4E00\u9053\u719F\u6089\u7684\u5C71\u8109\u3002\r\n\u90A3\u8F6E\u5ED3\u4F60\u7EDD\u4E0D\u4F1A\u8BA4\u9519\u3002\u90A3\u662F\u4F60\u7684\u6545\u571F\uFF0C\u5E0C\u7FBD\u3002\r\n\r\u4E00\u77AC\u95F4\uFF0C\u4F60\u7EC8\u4E8E\u660E\u767D\u4E86\u5EFA\u7B51\u5E08\u4E4B\u524D\u6240\u8BF4\u7684\u8BDD\u3002"
    isChoice: 0
    nextId: npc_12_2_3
    choices: []
