    backgroundId: NPC12/4
    characterId: 
    speakerName: 
    bodyText: "\u6574\u7247\u5927\u9646\u5E76\u4E0D\u662F\u5BFB\u5E38\u610F\u4E49\u4E0A\u7684\u5E73\u9762\uFF0C\u800C\u662F\u50CF\u83AB\u6BD4\u4E4C\u65AF\u73AF\u4E00\u822C\uFF0C\u9996\u5C3E\u76F8\u63A5\uFF0C\u5FAA\u73AF\u5F80\u590D\u3002\u4E5F\u6B63\u56E0\u5982\u6B64\uFF0C\u65E0\u8BBA\u4F60\u4ECE\u54EA\u4E2A\u65B9\u5411\u51FA\u53D1\uFF0C\u90FD\u6C38\u8FDC\u53EA\u80FD\u9065\u671B\u8FD9\u5EA7\u5854\uFF0C\u5374\u65E0\u6CD5\u771F\u6B63\u62B5\u8FBE\u3002\r\n\u5C31\u5728\u8FD9\u65F6\uFF0C\u5EFA\u7B51\u5E08\u7684\u58F0\u97F3\u4ECE\u4F60\u8EAB\u540E\u4F20\u6765\u3002"
