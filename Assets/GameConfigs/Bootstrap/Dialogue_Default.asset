    speakerName: "\u5360\u535C\u5E08"
    bodyText: "\u201C\u4F60\u7EC8\u4E8E\u6765\u4E86\uFF0C\u6211\u7B49\u4F60\u5F88\u4E45\u4E86\uFF0C\u53CD\u6297\u8005\u3002\u201D\n\u201C\u4F60\u60F3\u8981\u7684\u7B54\u6848\uFF0C\u90FD\u5728\u8FD9\u9897\u6C34\u6676\u7403\u91CC\u3002\u201D\n"
    isChoice: 0
    nextId: npc_2_1_3
    choices: []
  - id: npc_2_1_3
    timingKind: 4
    backgroundId: NPC2/2
    characterId: 
    speakerName: 
    bodyText: "\u4F60\u4F38\u51FA\u624B\uFF0C\u6307\u5C16\u89E6\u78B0\u5230\u6C34\u6676\u7403\u7684\u77AC\u95F4\uFF0C\u65E0\u6570\u7834\u788E\u7684\u753B\u9762\u5982\u6F6E\u6C34\u822C\u704C\u5165\u4F60\u7684\u8111\u6D77\u3002\r\n\u4F60\u770B\u89C1\u4E00\u5EA7\u6062\u5F18\u800C\u538B\u6291\u7684\u5BAB\u6BBF\u3002\u5934\u6234\u738B\u51A0\u7684\u8001\u5E74\u7537\u4EBA\u7AEF\u5750\u5728\u738B\u5EA7\u4E4B\u4E0A\uFF0C\u76EE\u5149\u6C89\u6C89\uFF0C\u4FEF\u89C6\u7740\u4E0B\u65B9\u7684\u4E00\u5207\u3002\r\n\r\u800C\u5728\u4ED6\u9762\u524D\uFF0C\u4E00\u4E2A\u9752\u5E74\u6B63\u624B\u6301\u5361\u724C\uFF0C\u671D\u7740\u738B\u5EA7\u4E00\u6B65\u6B65\u8D70\u53BB\u3002"
    isChoice: 0
    nextId: npc_2_1_4
    choices: []
  - id: npc_2_1_4
    timingKind: 4
    backgroundId: NPC2/2
    characterId: 
    speakerName: 
    bodyText: "\u56DB\u5468\u8FD8\u6709\u51E0\u5F20\u719F\u6089\u7684\u9762\u5B54\u3002\r\n\u82B1\u3001\u73B2\u5B50\u3001\u9F99\u2026\u2026\u4ED6\u4EEC\u90FD\u7AD9\u5728\u90A3\u91CC\uFF0C\u50CF\u662F\u5728\u89C1\u8BC1\u4EC0\u4E48\u3002\r\n\u4F60\u52AA\u529B\u770B\u6E05\u90A3\u540D\u9752\u5E74\u7684\u6A21\u6837\u3002\u5F53\u90A3\u5F20\u8138\u771F\u6B63\u6620\u5165\u773C\u4E2D\u65F6\uFF0C\u4F60\u7684\u547C\u5438\u4E0D\u7531\u5F97\u4E00\u6EDE\u3002\r\n\r\u90A3\u4E2A\u4EBA\uFF0C\u6B63\u662F\u4F60\u81EA\u5DF1\u3002"
    isChoice: 0
    nextId: npc_2_1_5
    choices: []
  - id: npc_2_1_5
    timingKind: 4
    backgroundId: NPC2/2
    characterId: 
    speakerName: 
    bodyText: "\u753B\u9762\u9AA4\u7136\u7834\u788E\uFF0C\u53C8\u518D\u4E00\u6B21\u91CD\u7EC4\u3002\r\n\u4F9D\u65E7\u662F\u90A3\u5EA7\u5BAB\u6BBF\u3002\u53EA\u662F\u8FD9\u4E00\u6B21\uFF0C\u738B\u5EA7\u4E0A\u7684\u4EBA\u4E0D\u518D\u662F\u90A3\u4E2A\u8001\u8005\u3002\r\n\r\u6570\u5343\u4EBA\u9ED1\u538B\u538B\u5730\u8DEA\u4F0F\u5728\u5927\u6BBF\u4E4B\u4E2D\uFF0C\u989D\u5934\u8D34\u5730\uFF0C\u8FDE\u7A7A\u6C14\u90FD\u50CF\u88AB\u538B\u5F97\u5598\u4E0D\u8FC7\u6C14\u6765\u3002\u73B2\u5B50\u548C\u9F99\u4E5F\u8DEA\u5728\u4EBA\u7FA4\u4E4B\u4E2D\uFF0C\u795E\u60C5\u606D\u987A\u800C\u6C89\u9ED8\u3002"
    isChoice: 0
    nextId: npc_2_1_6
    choices: []
  - id: npc_2_1_6
    timingKind: 4
    backgroundId: NPC2/3
    characterId: 
    speakerName: 
    bodyText: "\u800C\u5728\u90A3\u81F3\u9AD8\u4E4B\u5904\uFF0C\u5750\u7740\u7684\u662F\u4E00\u540D\u5934\u6234\u738B\u51A0\u7684\u5E74\u8F7B\u7537\u4EBA\u3002\r\n\u4ED6\u7F13\u7F13\u8F6C\u8FC7\u5934\u3002\r\n\u4F60\u770B\u6E05\u4E86\u4ED6\u7684\u8138\u3002\r\n\u4F9D\u7136\u662F\u4F60\u81EA\u5DF1\u3002"
    isChoice: 0
